<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CollectionSystem.Views.CollectionPage"
             Title="Kolekcja">
    <VerticalStackLayout Padding="10" Spacing="10">
        <Button Text="Dodaj element" Clicked="AddItem"/>
        <CollectionView x:Name="ItemsList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" FontAttributes="Bold"/>
                            <Label Text="{Binding Description}" FontSize="12"/>
                            <HorizontalStackLayout>
                                <Button Text="Edytuj" Clicked="EditItem"/>
                                <Button Text="Usuń" Clicked="DeleteItem"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
